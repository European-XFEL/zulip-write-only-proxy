{
  "name": "zwop-service-frontend",
  "private": true,
  "dependencies": {
    "daisyui": "^4.6.2",
    "tailwindcss": "^3.4.1"
  },
  "scripts": {
    "fetch-htmx": "cd src/zwop/frontend/static && wget -N https://unpkg.com/htmx.org@1.9.10/dist/htmx.js && wget -N https://unpkg.com/htmx.org@1.9.10/dist/htmx.min.js",
    "build-css": "tailwindcss -o src/zwop/frontend/static/main.css",
    "watch-css": "tailwindcss -o src/zwop/frontend/static/main.css --watch",
    "htmx": "pnpm run fetch-htmx",
    "build": "pnpm run build-css",
    "watch": "pnpm run watch-css"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "prettier-plugin-jinja-template": "^1.3.2",
    "prettier-plugin-tailwindcss": "^0.5.11"
  }
}
